# Zenthral Backend Environment Variables

# Flask
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-here-change-in-production
FLASK_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/zenthral
# Railway will auto-set this when you add PostgreSQL

# CORS (set to your Lovable domain in production)
CORS_ORIGINS=http://localhost:3000,https://your-app.lovable.app

# Optional: AI Provider Keys (for server-side operations)
# Users will set these locally via CLI
# OPENAI_API_KEY=sk-xxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxx
